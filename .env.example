# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yapi_denetim
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-a-strong-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# OCR (Tesseract)
TESSERACT_LANG=tur+eng

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# PDF Generation
PDF_LOGO_URL=

# Geofencing
DEFAULT_GEOFENCE_RADIUS_M=200

# SLA Thresholds (hours)
SLA_MOLD_REMOVAL_WARN_HOURS=16
SLA_MOLD_REMOVAL_MAX_HOURS=24
SLA_TEST_WINDOW_ADVANCE_HOURS=48
SLA_CURING_DISCHARGE_MAX_HOURS=2
