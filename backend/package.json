    "@types/multer": "^1.4.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.16.0",
    "node-pg-migrate": "^7.9.0",
